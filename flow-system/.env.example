# FlowSystem 配置文件
# 复制此文件为 .env 并填入你的配置

# === GLM Coding Plan API配置 ===
# 从 https://open.bigmodel.cn/ 获取API密钥
# 注意: 需要订阅GLM Coding Plan套餐（约99元/月），享受3倍用量和更低价格
ZHIPUAI_API_KEY=your_api_key_here

# GLM Coding Plan专属端点（使用OpenAI协议，不要修改）
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# 模型配置（默认GLM-4.7，也可选择GLM-4.5-Air）
MODEL_NAME=GLM-4.7

# === 系统配置 ===
# 并发数量 (默认: CPU核心数-1)
MAX_WORKERS=auto

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# === 演化参数 ===
# 种群大小
POPULATION_SIZE=8

# 最大代数
MAX_GENERATIONS=20

# 初始变异率
INITIAL_MUTATION_RATE=0.3

# 早停耐心值 (连续N代无改进则停止)
EARLY_STOP_PATIENCE=3

# === 缓存配置 ===
# 启用LLM缓存
ENABLE_CACHE=true

# === 知识库配置 ===
# 启用知识管理
ENABLE_KNOWLEDGE=true

# 模式提取阈值 (只学习高分代码)
PATTERN_THRESHOLD=0.9

# === 真涌现配置 ===
# 启用下行因果
ENABLE_DOWNWARD_CAUSATION=true

# Lyapunov指数阈值 (陷入吸引子)
LYAPUNOV_THRESHOLD=-0.1

# 有效信息阈值 (真涌现)
EFFECTIVE_INFO_THRESHOLD=0.5

# === UI配置 ===
# 启用实时可视化
ENABLE_VISUALIZATION=true

# 更新频率 (秒)
UPDATE_INTERVAL=0.5
